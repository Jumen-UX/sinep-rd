{
  "name": "sinep-rd",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "audit:migrations": "node scripts/audit-supabase-migrations.mjs",
    "audit:migrations:strict": "node scripts/audit-supabase-migrations.mjs --strict",
    "audit:routes": "node scripts/audit-admin-route-boundaries.mjs",
    "audit:routes:strict": "node scripts/audit-admin-route-boundaries.mjs --strict",
    "audit:structures": "node scripts/audit-structural-model-consumers.mjs",
    "audit:structures:strict": "node scripts/audit-structural-model-consumers.mjs --strict",
    "automation:check": "pnpm docs:check && pnpm docs:terminology && pnpm audit:migrations && pnpm e2e:affected",
    "check:legacy": "node scripts/check-no-legacy-pastoral.mjs",
    "check": "pnpm check:legacy && pnpm docs:check && pnpm docs:terminology && pnpm audit:migrations && pnpm audit:routes && pnpm audit:structures:strict && pnpm typecheck && pnpm test && pnpm build",
    "check:affected": "pnpm docs:check && pnpm docs:terminology && pnpm docs:affected && pnpm audit:migrations && pnpm typecheck && node scripts/run-affected-tests.mjs",
    "docs:affected": "node scripts/report-affected-documentation.mjs",
    "docs:check": "node scripts/check-documentation.mjs",
    "docs:index": "node scripts/generate-documentation-index.mjs",
    "docs:index:check": "node scripts/generate-documentation-index.mjs --check",
    "docs:terminology": "node scripts/check-documentation-terminology.mjs",
    "docs:terminology:strict": "node scripts/check-documentation-terminology.mjs --strict",
    "e2e:affected": "node scripts/select-affected-e2e.mjs",
    "e2e:affected:run": "node scripts/select-affected-e2e.mjs --run",
    "health:check": "node scripts/verify-health.mjs",
    "test": "node scripts/run-tests.mjs unit",
    "test:affected": "node scripts/run-affected-tests.mjs",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:all": "node scripts/run-tests.mjs all",
    "test:e2e:install": "pnpm dlx @playwright/test@1.61.0 install chromium",
    "test:e2e": "pnpm dlx --package=@playwright/test@1.61.0 --package=@axe-core/playwright@4.10.2 playwright test",
    "test:e2e:public": "pnpm dlx --package=@playwright/test@1.61.0 --package=@axe-core/playwright@4.10.2 playwright test e2e/public-accessibility.spec.mjs",
    "test:e2e:visual": "pnpm dlx --package=@playwright/test@1.61.0 playwright test e2e/visual-evidence.spec.mjs",
    "test:e2e:admin": "pnpm dlx --package=@playwright/test@1.61.0 --package=@axe-core/playwright@4.10.2 playwright test e2e/admin-import.spec.mjs",
    "test:e2e:access": "pnpm dlx --package=@playwright/test@1.61.0 playwright test e2e/admin-access-matrix.spec.mjs",
    "test:e2e:admin:mutation": "pnpm dlx --package=@playwright/test@1.61.0 --package=@axe-core/playwright@4.10.2 playwright test e2e/admin-import-mixed-person.spec.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "@supabase/ssr": "^0.12.2",
    "@supabase/supabase-js": "^2.110.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3"
  }
}
