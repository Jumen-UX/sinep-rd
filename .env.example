NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alternative legacy public key name supported by src/lib/supabase/config.ts
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public origin for Supabase Auth redirect URLs.
APP_BASE_URL=http://localhost:3000

# Server-only. Required for admin user invitation and account recovery endpoints.
# Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Optional manual Playwright execution. Leave E2E_BASE_URL empty to start the local Next.js server.
E2E_BASE_URL=
# Optional administrative flow. Use a dedicated non-production test account.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=

# Optional read-only access matrix. Store as a protected secret in CI, never in this file.
# JSON array fields: label, email, password, expectedState, ownEntityId,
# forbiddenEntityId and minimumVisibleDioceses.
E2E_ACCESS_PROFILES_JSON=

# Explicitly guarded mutating E2E. Never enable against production.
E2E_ALLOW_MUTATIONS=false
# Existing person in the same non-production database, used to verify a real noop.
E2E_PERSON_REFERENCE_CODE=
E2E_PERSON_FIRST_NAME=
E2E_PERSON_LAST_NAME=

