NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alternative legacy public key name supported by src/lib/supabase/config.ts
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical public origin for Supabase Auth redirect URLs.
APP_BASE_URL=http://localhost:3000

# Server-only. Required for admin user invitation and account recovery endpoints.
# Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Optional manual Playwright execution. Leave E2E_BASE_URL empty to start the local Next.js server.
E2E_BASE_URL=
# Optional administrative flow. Use a dedicated non-production test account.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
